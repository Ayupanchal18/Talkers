{
  "expo": {
    "name": "Vidss",
    "slug": "vidss-mobile",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "scheme": "vidss",
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.vidss.app",
      "infoPlist": {
        "NSCameraUsageDescription": "Allow Vidss to access your camera for video calls.",
        "NSMicrophoneUsageDescription": "Allow Vidss to access your microphone for voice calls."
      }
    },
    "android": {
      "package": "com.vidss.app",
      "adaptiveIcon": {
        "backgroundColor": "#0c1220",
        "foregroundImage": "./assets/icon.png"
      },
      "permissions": [
        "CAMERA",
        "RECORD_AUDIO",
        "MODIFY_AUDIO_SETTINGS"
      ],
      "intentFilters": [
        {
          "action": "VIEW",
          "autoVerify": true,
          "data": [
            {
              "scheme": "https",
              "host": "vidss-frontend.onrender.com",
              "pathPrefix": "/lobby"
            },
            {
              "scheme": "https",
              "host": "vidss-frontend.onrender.com",
              "pathPrefix": "/room"
            }
          ],
          "category": [
            "BROWSABLE",
            "DEFAULT"
          ]
        }
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      [
        "@config-plugins/react-native-webrtc",
        {
          "cameraPermission": "Allow Vidss to access your camera to make video calls.",
          "microphonePermission": "Allow Vidss to access your microphone to make voice calls."
        }
      ]
    ]
  }
}
