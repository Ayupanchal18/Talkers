# Production Environment Variables (Example)
# DO NOT commit this file with real values!
# These will be set in Render Dashboard

NODE_ENV=production
PORT=10000

# Database URL - Will be injected by Render from PostgreSQL service
DATABASE_URL=postgresql://user:password@host:port/vidss?schema=public

# JWT Secrets - Use Render's auto-generate or create secure random strings
# Generate at: https://randomkeygen.com/ (use 64-character keys)
JWT_SECRET=your_production_jwt_secret_min_64_characters_long
JWT_REFRESH_SECRET=your_production_jwt_refresh_secret_min_64_characters_long

# Frontend URL - Your Render frontend URL or custom domain
FRONTEND_URL=https://vidss-frontend.onrender.com
